# ── App identity ──────────────────────────────────────────────
APP_NAME=Hospital Nav API
APP_VERSION=0.1.0
APP_DESCRIPTION=Indoor hospital navigation system — QR, WiFi, CV location fusion + A* routing

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (* for all)
CORS_ORIGINS=*

# ── Redis (for future use) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Graph data file ──────────────────────────────────────────
# Path to the hospital graph JSON (defaults to backend/hospital_graph.json)
# GRAPH_FILE=hospital_graph.json
